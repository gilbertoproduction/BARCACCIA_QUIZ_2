{
  "entities": {
    "Poll": {
      "title": "Poll",
      "description": "A poll within the application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "createdAt"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A user's vote on a poll",
      "type": "object",
      "properties": {
        "pollId": { "type": "string" },
        "member": { "type": "string", "enum": ["SIMO", "MARCO", "DAVE", "PIETRO", "FILO"] },
        "selectedOptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["pollId", "member", "selectedOptions", "timestamp"]
    }
  },
  "firestore": {
    "/polls/{pollId}": {
      "schema": "Poll",
      "description": "Collection of polls"
    },
    "/votes/{voteId}": {
      "schema": "Vote",
      "description": "Collection of votes cast by members"
    }
  }
}
