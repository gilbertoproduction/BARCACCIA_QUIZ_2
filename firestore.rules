rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isMember(m) {
      return m in ['SIMO', 'MARCO', 'DAVE', 'PIETRO', 'FILO'];
    }

    // Polls rules
    match /polls/{pollId} {
      allow read: if true;
      allow write: if false; // System defined
    }

    // Votes rules
    match /votes/{voteId} {
      allow read: if true;
      allow create: if isValidVote(request.resource.data);
      allow update: if false; // Simple version: no updates without persistent identity
      allow delete: if false;
    }

    function isValidVote(data) {
      return data.keys().hasAll(['pollId', 'member', 'selectedOptions', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.pollId is string && 
             data.pollId.size() <= 128 &&
             isMember(data.member) &&
             data.selectedOptions is list &&
             data.selectedOptions.size() <= 100;
    }
  }
}
